DATABASE_URL=postgresql://transitops:transitops@localhost:5432/transitops
JWT_SECRET=transitops-dev-secret-change-me
PORT=8080

# Base URL of the Python ml-service (see /ml-service). Used by /ml/* proxy routes.
ML_SERVICE_URL=http://localhost:8000

# Google Cloud OAuth Client ID (Web application type) used to verify "Sign in
# with Google" ID tokens on POST /auth/google. Same value as the frontend's
# VITE_GOOGLE_CLIENT_ID. Create one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
